{
  "compilerOptions": {
    "paths": {
      "apis": ["./projects/apis/index.ts"],
      "common": ["./projects/common/index.ts"],
      "functions": ["./projects/functions/index.ts"],
      "domains": ["./projects/domains/index.ts"],
      "resources": ["./projects/resources/index.ts"],
    },
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": ["projects/**/*"],
  "exclude": ["node_modules", "dist"],
}
